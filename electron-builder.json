{
  "appId": "com.tinte.desktop",
  "productName": "Tinte",
  "directories": {
    "output": "release/.tmp/default"
  },
  "files": [
    "electron/**/*",
    "renderer/dist/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "core/dist",
      "to": "bin",
      "filter": [
        "**/*"
      ]
    }
  ],
  "mac": {
    "category": "public.app-category.developer-tools",
    "identity": null
  }
}
