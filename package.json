{
  "name": "biene-desktop",
  "private": true,
  "version": "0.2.0",
  "description": "Desktop shell for the Biene local AI coding assistant",
  "author": "yu",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "start": "electron .",
    "build:renderer": "npm --prefix renderer run build",
    "build:core": "node scripts/build-core.cjs",
    "package:desktop": "electron-builder --config electron-builder.json",
    "build": "node scripts/release.cjs all",
    "build:mac": "node scripts/release.cjs mac",
    "build:win": "node scripts/release.cjs win"
  },
  "devDependencies": {
    "electron": "^35.3.0",
    "electron-builder": "^26.0.12"
  }
}
